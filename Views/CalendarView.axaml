<UserControl
    x:Class="Aniki.Views.CalendarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:vm="clr-namespace:Aniki.ViewModels;assembly=Aniki"
    xmlns:anime="clr-namespace:Aniki.Services.Anime"
    x:DataType="vm:CalendarViewModel">
    <UserControl.Styles>
        <Style Selector="Button.today-button">
            <Setter Property="Background" Value="{StaticResource RedColor}" />
            <Setter Property="Foreground" Value="{StaticResource White}" />
            <Setter Property="BorderBrush" Value="{StaticResource RedColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style Selector="ToolTip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="MaxWidth" Value="520" />
        </Style>

        <Style Selector="Border.anime-card">
            <Setter Property="RenderTransform" Value="scaleX(1) scaleY(1)" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.anime-card:pointerover">
            <Setter Property="RenderTransform" Value="scaleX(1.04) scaleY(1.04)" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="ScrollViewer /template/ ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#444444" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#666666" />
        </Style>
    </UserControl.Styles>

    <DockPanel x:Name="Root" Margin="0,50,0,0" Background="{StaticResource BackgroundGray}">
        <Border
            Padding="16,12"
            Background="{StaticResource BackgroundBlack}"
            BorderBrush="#333333"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Classes="nav-button"
                        Command="{Binding GoBackWeekCommand}"
                        ToolTip.Tip="Go by back one week">
                        <Image Source="{SvgImage /Resources/Icons/doubleChevronLeft_icon.svg}" Width="16" Height="16"/>
                    </Button>
                    <Button
                        Classes="nav-button"
                        Command="{Binding GoBackDayCommand}"
                        ToolTip.Tip="Previous day">
                        <Image Source="{SvgImage /Resources/Icons/chevronLeft_icon.svg}" Width="16" Height="16"/>
                    </Button>

                    <Button
                        Classes="today-button"
                        Command="{Binding GoToStartCommand}"
                        Content="Home"
                        ToolTip.Tip="Go to start" />
                    <Button
                        Classes="nav-button"
                        Command="{Binding GoForwardDayCommand}"
                        ToolTip.Tip="Next day">
                        <Image Source="{SvgImage /Resources/Icons/chevronRight_icon.svg}" Width="16" Height="16"/>
                    </Button>
                    <Button
                        Classes="nav-button"
                        Command="{Binding GoForwardWeekCommand}"
                        ToolTip.Tip="Go forward by one week">
                        <Image Source="{SvgImage /Resources/Icons/doubleChevronRight_icon.svg}" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ToggleButton
                        Content="My Anime"
                        IsChecked="{Binding ShowOnlyMyAnime}" 
                        IsVisible="{Binding Source={x:Static anime:AnimeService.IsLoggedIn}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Loading indicator  -->
        <Border
            Height="4"
            Background="{StaticResource Background0}"
            DockPanel.Dock="Top"
            IsVisible="{Binding IsLoading}">
            <ProgressBar
                Height="4"
                Background="Transparent"
                Foreground="{StaticResource RedColor}"
                IsIndeterminate="True" />
        </Border>

        <ScrollViewer
            x:Name="MainScrollViewer"
            Background="{StaticResource BackgroundBlack}"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Visible"
            Margin="0,0,6,0">

            <ItemsControl 
                Margin="8,0" 
                ItemsSource="{Binding Days}" 
                Background="{StaticResource BackgroundGray}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="{Binding ColumnIndex, Converter={StaticResource CalendarColumnBorderThicknessConverter}}"
                            Background="{StaticResource BackgroundGray}">

                            <Grid Background="{StaticResource BackgroundGray}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Day header  -->
                                <Border
                                    Grid.Row="0"
                                    Padding="12,8"
                                    Background="{StaticResource BackgroundBlack}"
                                    BorderBrush="#333333"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource White}"
                                            Text="{Binding DayName}" />

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="#AAAAAA"
                                            Text="{Binding Date, StringFormat='MMM dd'}" />
                                    </Grid>
                                </Border>

                                <ItemsControl 
                                    Grid.Row="1"
                                    ItemsSource="{Binding Items}" 
                                    Background="{StaticResource BackgroundGray}">
                                    <ItemsControl.Styles>
                                        <Style Selector="ContentPresenter &gt; StackPanel.calendar-anime-row">
                                            <Setter Property="Background" Value="#1E1E1E" />
                                        </Style>
                                        <Style Selector="ContentPresenter:nth-child(odd) &gt; StackPanel.calendar-anime-row">
                                            <Setter Property="Background" Value="#252525" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Classes="calendar-anime-row" Tapped="OnAnimeTapped">
                                                <ToolTip.Tip>
                                                    <Border
                                                        Background="{StaticResource BackgroundBlack}"
                                                        CornerRadius="10"
                                                        Padding="0"
                                                        MaxWidth="480"
                                                        MaxHeight="200"
                                                        ClipToBounds="True"
                                                        BorderBrush="#555555"
                                                        BorderThickness="1.5">
                                                        <Grid ColumnDefinitions="120,*">
                                                            <Border
                                                                Grid.Column="0"
                                                                CornerRadius="10,0,0,10"
                                                                ClipToBounds="True">
                                                                <Image
                                                                    asyncImageLoader:ImageLoader.Source="{Binding ImageUrl}"
                                                                    Stretch="UniformToFill" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Margin="14,12,14,14" Spacing="6">
                                                                <TextBlock
                                                                    Text="{Binding Title}"
                                                                    FontSize="15"
                                                                    FontWeight="Bold"
                                                                    Foreground="{StaticResource White}"
                                                                    TextWrapping="Wrap"
                                                                    MaxLines="2"
                                                                    TextTrimming="CharacterEllipsis" />

                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock
                                                                        Text="{Binding EpisodeInfo}"
                                                                        FontSize="12"
                                                                        Foreground="#AAAAAA" />
                                                                    <TextBlock
                                                                        Text="{Binding AiringAt, StringFormat='h:mm tt'}"
                                                                        FontSize="12"
                                                                        Foreground="#AAAAAA" />
                                                                </StackPanel>

                                                                <TextBlock
                                                                    Text="{Binding Genres}"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource RedColor}"
                                                                    FontWeight="Medium"
                                                                    TextWrapping="Wrap"
                                                                    IsVisible="{Binding Genres, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                                                <TextBlock
                                                                    Text="{Binding Description}"
                                                                    FontSize="12"
                                                                    Foreground="#CCCCCC"
                                                                    TextWrapping="Wrap"
                                                                    MaxLines="5"
                                                                    LineHeight="18"
                                                                    TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </ToolTip.Tip>

                                                <!--  Air time  -->
                                                <TextBlock
                                                    Margin="8,4,0,0"
                                                    FontSize="11"
                                                    Foreground="#666666"
                                                    Text="{Binding AiringAt, StringFormat='h:mm tt'}" />

                                                <Border
                                                    Classes="anime-card"
                                                    Width="180"
                                                    Margin="8,2,8,4"
                                                    Padding="0"
                                                    Background="{StaticResource BackgroundBlack}"
                                                    BorderBrush="{Binding Type, Converter={StaticResource AnimeTypeToColorConverter}}"
                                                    BorderThickness="3,0,3,0"
                                                    CornerRadius="8">

                                                    <Grid Cursor="Hand">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border
                                                            Grid.Column="0"
                                                            Width="48"
                                                            Height="64"
                                                            CornerRadius="6,0,0,6"
                                                            ClipToBounds="True">
                                                            <Image
                                                                asyncImageLoader:ImageLoader.Source="{Binding ImageUrl}"
                                                                Stretch="UniformToFill"
                                                                RenderOptions.BitmapInterpolationMode="LowQuality" />
                                                        </Border>

                                                        <!--  Content area  -->
                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Margin="12,6"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand">

                                                            <!--  Title  -->
                                                            <TextBlock
                                                                FontSize="13"
                                                                FontWeight="Medium"
                                                                Foreground="{StaticResource White}"
                                                                LineHeight="16"
                                                                MaxLines="2"
                                                                Text="{Binding Title}"
                                                                TextTrimming="CharacterEllipsis"
                                                                TextWrapping="Wrap" />

                                                            <!--  Episode info  -->
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontSize="11"
                                                                Foreground="#AAAAAA"
                                                                Text="{Binding EpisodeInfo}" />
                                                        </StackPanel>

                                                        <Border
                                                            Grid.Column="2"
                                                            Width="8"
                                                            Height="8"
                                                            Margin="0,6,8,6"
                                                            VerticalAlignment="Top"
                                                            Background="{StaticResource RedColor}"
                                                            CornerRadius="4"
                                                            IsVisible="{Binding IsAiringNow}" />
                                                        
                                                        <Path
                                                            Grid.Column="2"
                                                            Width="16"
                                                            Height="16"
                                                            Margin="0,6,26,0"
                                                            VerticalAlignment="Top"
                                                            HorizontalAlignment="Right"
                                                            Fill="{StaticResource RedColor}"
                                                            IsVisible="{Binding IsBookmarked}"
                                                            Data="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>